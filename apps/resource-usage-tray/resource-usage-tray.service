[Unit]
Description=Resource usage tray indicator
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
PassEnvironment=DISPLAY WAYLAND_DISPLAY XAUTHORITY DBUS_SESSION_BUS_ADDRESS XDG_RUNTIME_DIR XDG_CURRENT_DESKTOP
ExecStart=%h/.local/bin/resource-usage-tray
Restart=on-failure
RestartSec=5

[Install]
WantedBy=graphical-session.target
